<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- شريط العنوان -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:title="وقتك"
            android:titleTextColor="@color/accent_gold"/>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- تحميل -->
            <ProgressBar
                android:id="@+id/progress_bar"
                style="?android:attr/progressBarStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="100dp"
                android:indeterminateTint="@color/accent_gold"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/layout_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="24dp">

                <!-- ═══ بطاقة الموقع والتاريخ ═══ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp"
                    android:paddingHorizontal="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_city"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="جاري تحديد الموقع..."
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tv_date"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"/>

                            <TextView
                                android:id="@+id/tv_hijri"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="1dp"
                                android:textColor="@color/accent_gold"
                                android:textSize="12sp"/>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_set_location"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="تغيير"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <!-- فاصل -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginTop="10dp"
                        android:background="@color/divider"/>
                </LinearLayout>

                <!-- ═══ بطاقة الصلاة القادمة ═══ -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/accent_green_dark"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="4dp"
                    app:strokeColor="@color/accent_gold"
                    app:strokeWidth="0.8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="20dp"
                        android:paddingHorizontal="16dp">

                        <TextView
                            android:id="@+id/tv_next_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الصلاة القادمة"
                            android:textColor="#99FFFFFF"
                            android:textSize="12sp"
                            android:letterSpacing="0.05"/>

                        <TextView
                            android:id="@+id/tv_next_prayer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="—"
                            android:textColor="@android:color/white"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tv_countdown"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/accent_gold_light"
                            android:textSize="34sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ═══ بطاقة الجمعة (يوم الجمعة فقط) ═══ -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_jumuah"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/surface_card"
                    app:cardCornerRadius="14dp"
                    app:strokeColor="@color/accent_gold"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="صلاة الجمعة"
                                android:textColor="@color/accent_gold"
                                android:textSize="15sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="اليوم"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_jumuah_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ═══ رأس الجدول ═══ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:id="@+id/tv_header_prayer"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="الصلاة"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.08"/>

                    <TextView
                        android:id="@+id/tv_header_adhan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="الأذان  |  الإقامة"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.08"/>
                </LinearLayout>

                <!-- ═══ قائمة المواقيت ═══ -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_prayers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>

            </LinearLayout>
        </FrameLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
