<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    android:background="@drawable/bg_prayer_item"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="18dp"
    android:paddingVertical="16dp">

    <!-- خط ذهبي رفيع على اليسار للصلاة القادمة -->
    <View
        android:id="@+id/view_indicator"
        android:layout_width="3dp"
        android:layout_height="36dp"
        android:layout_marginEnd="14dp"
        android:background="@color/accent_gold"
        android:visibility="invisible"/>

    <!-- اسم الصلاة + وقت الإقامة -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_prayer_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_iqama_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- وقت الأذان -->
    <TextView
        android:id="@+id/tv_prayer_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/accent_gold"
        android:textSize="19sp"
        android:textStyle="bold"
        android:fontFamily="monospace"/>

</LinearLayout>
